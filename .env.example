# Copy this file to .env. Never commit the resulting .env file.
MQTT_HOST=venus.local
MQTT_PORT=8883
MQTT_USERNAME=admin

# For local development only. Prefer MQTT_PASSWORD_FILE in containers.
# MQTT_PASSWORD=replace-with-the-gx-device-password
# MQTT_PASSWORD_FILE=/run/secrets/gx_mqtt_password

# Current GX devices commonly serve a self-signed certificate on port 8883.
MQTT_TLS=true
MQTT_TLS_INSECURE=true

OUTPUT_PATH=output/solar.json
LOG_LEVEL=INFO
# Set this if the broker requires periodic full-value refresh requests.
# VRM_PORTAL_ID=xxxxxxxxxxxx

# Neocities publisher worker. Keep the real API key outside this file.
# NEOCITIES_API_KEY_FILE=/run/secrets/neocities_api_key
NEOCITIES_REMOTE_PATH=solar.json
# Neocities asks recurring API users to limit updates to once per minute.
NEOCITIES_MIN_UPLOAD_INTERVAL=300
NEOCITIES_SETTLE_SECONDS=10
NEOCITIES_POLL_SECONDS=2
NEOCITIES_REQUEST_TIMEOUT=15
